# Forma Configuration
# Copy this file to .env and fill in your values

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Extraction LLM configuration (for entity/relationship/fact extraction)
# Used internally by Forma's RAG pipeline, not exposed as endpoint
# Example for LM Studio:
# EXTRACTOR_BASE_URL=http://localhost:1234/v1
# EXTRACTOR_API_KEY=  (LM Studio doesn't require auth)
# EXTRACTOR_MODEL_NAME=smollm3-3b-128k

# Leave empty to use upstream from database (configured via Web UI):
EXTRACTOR_BASE_URL=
EXTRACTOR_API_KEY=
EXTRACTOR_MODEL_NAME=
EXTRACTOR_TIMEOUT=120.0

# GrafitoDB configuration (SQLite-backed graph + vector database)
# Single file database - minimal file descriptors compared to ChromaDB + CogDB
GRAFITODB_PATH=./grafito_data/forma.db
# SentenceTransformer model for embeddings (used for semantic search)
GRAFITODB_EMBEDDING_MODEL=all-MiniLM-L6-v2
# Embedding dimension (depends on model: all-MiniLM-L6-v2 = 384)
GRAFITODB_VECTOR_DIM=384
# Local cache path for embedding model (avoids downloading on each restart)
GRAFITODB_MODEL_CACHE_PATH=./models

# Request history configuration (for web UI)
FORMA_DB_PATH=./data/forma.db
HISTORY_MAX_RECORDS=100
HISTORY_ENABLED=true