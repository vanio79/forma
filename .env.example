# Forma Configuration
# Copy this file to .env and fill in your values

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Upstream API configuration
# Example for OpenAI:
# UPSTREAM_BASE_URL=https://api.openai.com/v1
# UPSTREAM_API_KEY=sk-your-api-key

# Example for local LLM (e.g., llama.cpp, vLLM, Ollama):
# UPSTREAM_BASE_URL=http://localhost:8080/v1
# UPSTREAM_API_KEY=

# For providers that need no auth (like local servers):
UPSTREAM_BASE_URL=http://localhost:8080/v1
UPSTREAM_API_KEY=

# Request timeout in seconds (default: 300 for long requests)
UPSTREAM_TIMEOUT=300.0

# Embedding API configuration (separate endpoint for embeddings)
# If set, embeddings go to this endpoint instead of UPSTREAM_BASE_URL
# Example for LM Studio:
# EMBEDDING_BASE_URL=http://localhost:1234/v1
# EMBEDDING_API_KEY=  (LM Studio doesn't require auth)
# EMBEDDING_MODEL_NAME=text-embedding-all-minilm-l6-v2-embedding

# Leave empty to use UPSTREAM_BASE_URL for embeddings:
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=
EMBEDDING_TIMEOUT=60.0

# Extraction LLM configuration (for entity/relationship/fact extraction)
# Used internally by Forma's RAG pipeline, not exposed as endpoint
# Example for LM Studio:
# EXTRACTOR_BASE_URL=http://localhost:1234/v1
# EXTRACTOR_API_KEY=  (LM Studio doesn't require auth)
# EXTRACTOR_MODEL_NAME=smollm3-3b-128k

# Leave empty to use UPSTREAM_BASE_URL for extraction:
EXTRACTOR_BASE_URL=
EXTRACTOR_API_KEY=
EXTRACTOR_MODEL_NAME=
EXTRACTOR_TIMEOUT=120.0

# Optional: Model name mapping
# Format: "local_name:upstream_name,local_name2:upstream_name2"
# Example: "gpt-4:llama-3-70b,gpt-3.5-turbo:llama-3-8b"
MODEL_MAPPING=

# ChromaDB configuration (for storing facts and recipes)
# If CHROMADB_PERSIST_DIRECTORY is set, uses embedded file-based storage (port ignored)
# If empty, connects to a ChromaDB server at CHROMADB_HOST:CHROMADB_PORT
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_PERSIST_DIRECTORY=

# CogDB configuration (for storing entities and relationships as graph)
COGDB_HOME=forma_graph
COGDB_PATH_PREFIX=./cog_data

# File descriptor limits (prevent "too many open files" under load)
# ChromaDB max open files (default: 256, lower if hitting system limits)
CHROMADB_MAX_FILE_HANDLES=256
# CogDB index capacity - hash table size for indices (default: 50000, lower = fewer indices)
COGDB_INDEX_CAPACITY=50000
# CogDB L2 cache size - number of cached entries (default: 50000, lower = fewer cached handles)
COGDB_L2_CACHE_SIZE=50000